# Build context for the Rebalancer Explorer Next.js app image.
# Keep this lean: local install/build artifacts must never leak into the image
# (they are regenerated inside the build).
node_modules
.next
out
build
coverage
.git
.DS_Store
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Pins the internal npm mirror; excluded so yarn regenerates a public-registry lock.
yarn.lock
# Internal-only fb/ adapters (@nest/*-backed); also stripped by ShipIt.
**/fb
